# ─────────────────────────────────────────────────────────────────
#  Spanish Quiz App — Environment Variables
#  Copy this file to .env and fill in real values before deploying.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=production

# Port the app listens on (DigitalOcean uses 8080 by default on App Platform)
PORT=8080

# Secret key for express-session cookie signing — use a long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-very-long-random-string-here

# Admin password — set ONE of the following:
#
# Option A (recommended for production): bcrypt hash
#   Generate with: node -e "const b=require('bcryptjs'); b.hash('YourPassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Option B (dev/first-boot only): plain text (less secure)
ADMIN_PASSWORD=BmyloAdmin2026

# Path to SQLite database directory (must be the DigitalOcean persistent volume mount path)
DB_DIR=/var/data
