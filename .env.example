# ─────────────────────────────────────────────────────────────────
#  Spanish Quiz App — Environment Variables
#  Copy this file to .env and fill in real values before deploying.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

NODE_ENV=production

# Port (DigitalOcean App Platform uses 8080 by default)
PORT=8080

# PostgreSQL connection string — DigitalOcean will provide this
# when you attach a Managed Database to your app.
# It looks like: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/quizdb

# Secret key for session cookies — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-very-long-random-string-here

# Admin password — set ONE of the following:
#
# Option A (recommended): bcrypt hash
#   Generate with: node -e "const b=require('bcryptjs'); b.hash('YourPassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Option B (dev only): plain text
ADMIN_PASSWORD=BmyloAdmin2026

# Anthropic API key — required for AI grading of paper test scans
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
